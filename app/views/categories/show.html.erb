<div class="container mt-5">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Categories", categories_path %></li>
      <li class="breadcrumb-item active"><%= @category.name %></li>
    </ol>
  </nav>

  <div class="bg-light p-5 rounded-5 mb-5 shadow-sm">
    <h1 class="display-4 fw-bold"><%= @category.name %></h1>
    <p class="lead text-muted"><%= @category.description %></p>
  </div>

  <h2 class="fw-bold mb-4">Events in this Category</h2>
  
  <div class="row">
    <% if @category.events.any? %>
      <% @category.events.each do |event| %>
        <div class="col-md-6 col-lg-4 mb-4">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <h5 class="card-title fw-bold"><%= event.title %></h5>
              <p class="text-muted small"><i class="bi bi-calendar"></i> <%= event.date.strftime("%B %d, %Y") %></p>
              <%= link_to "View Details", event_path(event), class: "btn btn-primary btn-sm" %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="col-12">
        <div class="alert alert-info">No events found in this category yet.</div>
      </div>
    <% end %>
  </div>
</div>
