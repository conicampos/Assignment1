<!DOCTYPE html>
<html lang="en">
  <head>
    <title>EventHub | University Community</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/引入/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet">

    <style>
      body { font-family: 'Inter', sans-serif; display: flex; flex-direction: column; min-height: 100vh; }
      .bg-gradient-custom { background: linear-gradient(135deg, #0d6efd 0%, #003d99 100%); }
      main { flex: 1; }
    </style>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
      <div class="container">
        <%= link_to root_path, class: "navbar-brand fw-bold" do %>
          <span class="text-primary">Event</span>Hub
        <% end %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarMain">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item"><%= link_to "Events", events_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Categories", categories_path, class: "nav-link" %></li>
          </ul>
          <div class="d-flex gap-2">
            <a href="#" class="btn btn-outline-light btn-sm">Log In</a>
            <a href="#" class="btn btn-primary btn-sm">Sign Up</a>
          </div>
        </div>
      </div>
    </nav>

    <main>
      <%= yield %>
    </main>

<footer class="bg-dark text-white py-5 mt-5">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-md-6 text-center text-md-start">
        <h5 class="fw-bold mb-1 text-primary">EventHub</h5>
        <p class="mb-0 small text-muted">&copy; 2026. All rights reserved.</p>
      </div>
      <div class="col-md-6 text-center text-md-end mt-4 mt-md-0">
        <p class="mb-0"><strong>Course:</strong> Web Technologies</p>
        <p class="mb-0"><strong>Year:</strong> 2026</p>
        <p class="mb-0"><strong>Team:</strong> Constanza Campos, René Montoya</p>
      </div>
    </div>
  </div>
</footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>