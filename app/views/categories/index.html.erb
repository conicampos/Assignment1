<div class="container mt-5">
  <div class="text-center mb-5">
    <h1 class="fw-bold">Event Categories</h1>
    <p class="text-muted lead">Explore events by your areas of interest.</p>
  </div>

  <div class="row g-4">
    <% @categories.each do |category| %>
      <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 transition-hover">
          <div class="card-body p-4 text-center">
            <div class="mb-3 text-primary h1">
              <i class="bi bi-tag-fill"></i>
            </div>
            <h3 class="card-title fw-bold"><%= category.name %></h3>
            <p class="card-text text-muted"><%= category.description %></p>
            <p class="small fw-bold text-primary"><%= category.events.count %> Upcoming Events</p>
            <%= link_to "View Events", category_path(category), class: "btn btn-outline-primary mt-3 w-100" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
  .transition-hover { transition: transform 0.2s; }
  .transition-hover:hover { transform: translateY(-5px); }
</style>
