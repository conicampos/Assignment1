<header class="bg-gradient-custom text-white py-5">
  <div class="container py-5">
    <div class="row align-items-center">
      <div class="col-lg-7 text-center text-lg-start">
        <h1 class="display-3 fw-bold mb-3">Connect, Engage, and Learn</h1>
        <p class="lead mb-4">The ultimate platform for university life. Discover events and share your experiences.</p>
        <div class="d-grid gap-3 d-sm-flex justify-content-sm-center justify-content-lg-start">
          <%= link_to "Browse Events", events_path, class: "btn btn-light btn-lg px-4 fw-bold" %>
        </div>
      </div>
      <div class="col-lg-5 d-none d-lg-block">
        <img src="https://images.unsplash.com/photo-1540575861501-7cf05a4b125a?auto=format&fit=crop&w=500&q=80" alt="University Event" class="img-fluid rounded-5 shadow-lg">
      </div>
    </div>
  </div>
</header>

<section class="py-5 bg-light">
  <div class="container text-center py-5">
    <h2 class="fw-bold">Welcome to EventHub</h2>
    <p class="text-muted">Explore our categories and find the next big campus event.</p>
    <%= link_to "View Categories", categories_path, class: "btn btn-outline-primary" %>
  </div>
</section>