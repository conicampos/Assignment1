<div class="container mt-5">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Events", events_path %></li>
      <li class="breadcrumb-item active"><%= @event.title %></li>
    </ol>
  </nav>

  <div class="row">
    <div class="col-lg-8">
      <div class="card shadow-sm border-0 p-4 mb-4">
        <span class="badge bg-primary w-25 mb-3"><%= @event.category.name %></span>
        <h1 class="fw-bold mb-3"><%= @event.title %></h1>
        <p class="lead text-muted"><%= @event.description %></p>
        
        <hr class="my-4">
        
        <div class="row text-center">
          <div class="col-md-4">
            <i class="bi bi-calendar-event text-primary h3"></i>
            <p class="mb-0 fw-bold">Date</p>
            <p><%= @event.date.strftime("%B %d, %Y") %></p>
          </div>
          <div class="col-md-4">
            <i class="bi bi-geo-alt text-primary h3"></i>
            <p class="mb-0 fw-bold">Location</p>
            <p><%= @event.location %></p>
          </div>
          <div class="col-md-4">
            <i class="bi bi-people text-primary h3"></i>
            <p class="mb-0 fw-bold">Capacity</p>
            <p><%= @event.capacity %> spots</p>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card shadow-sm border-0 p-4 text-center bg-light">
        <h4 class="fw-bold mb-3">Interested?</h4>
        <p>Organized by: <strong><%= @event.organizer.name %></strong></p>
        <button class="btn btn-primary btn-lg w-100 disabled">Register (Assignment 3)</button>
        <p class="small text-muted mt-3">Registrations will be enabled in the next phase.</p>
      </div>
    </div>
  </div>
</div>